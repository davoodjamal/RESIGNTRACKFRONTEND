                if (parent) {
                    if (this.checked) {
                        parent.classList.add('border-primary-container');
                    } else {
                        parent.classList.remove('border-primary-container');
                    }
                }
            });
        });

        // Save button feedback
        const saveBtn = document.querySelector('.bg-primary-container');
        if (saveBtn) {
            saveBtn.addEventListener('click', () => {
                const originalText = saveBtn.innerHTML;
                saveBtn.innerText = 'Saving...';
                saveBtn.disabled = true;
                setTimeout(() => {
                    saveBtn.innerText = 'Changes Saved!';
                    saveBtn.classList.replace('bg-primary-container', 'bg-green-600');
                    setTimeout(() => {
                        saveBtn.innerHTML = originalText;
                        saveBtn.classList.replace('bg-green-600', 'bg-primary-container');
                        saveBtn.disabled = false;
                    }, 2000);
                }, 1000);
