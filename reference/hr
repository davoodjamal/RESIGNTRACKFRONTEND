    <script>
        // Simple search focus effect
        const searchInput = document.querySelector('input[type="text"]');
        const searchContainer = searchInput.closest('.relative');

        searchInput.addEventListener('focus', () => {
            searchContainer.classList.add('ring-primary-fixed');
        });

        searchInput.addEventListener('blur', () => {
            searchContainer.classList.remove('ring-primary-fixed');
        });

        // Hover animation for task rows
        const attachRowHoverEffect = (row) => {
            row.addEventListener('mouseenter', () => {
                row.style.transform = 'translateX(4px)';
            });
            row.addEventListener('mouseleave', () => {
                row.style.transform = 'translateX(0px)';
            });
        };

        document.querySelectorAll('tr').forEach(attachRowHoverEffect);

        /**
         * TASK FILTERING AND SORTING LOGIC
         */
        const taskTableBody = document.querySelector('#task-table tbody');
        const filterBtns = document.querySelectorAll('.filter-btn');
        const sortBtn = document.getElementById('sort-btn');
        const taskCountEl = document.getElementById('task-count');

        let currentSortOrder = 'asc'; // 'asc' or 'desc'

        // Function to update task count display
        const updateTaskCount = () => {
            const visibleRows = Array.from(taskTableBody.querySelectorAll('tr')).filter(tr => tr.style.display !== 'none');
            const totalTasks = 142; // Keeping the original static total for visual consistency
            taskCountEl.textContent = `Showing ${visibleRows.length} of ${totalTasks} tasks`;
        };

        // Filtering Logic
        filterBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                const filterValue = btn.getAttribute('data-filter');

                // Update UI state
                filterBtns.forEach(b => {
                    b.classList.remove('active', 'bg-secondary-container', 'text-on-secondary-container');
                    b.classList.add('text-on-surface-variant', 'hover:bg-surface-container-low');
                });
                btn.classList.add('active');
                btn.classList.remove('text-on-surface-variant', 'hover:bg-surface-container-low');

                // Filter Rows
                const rows = taskTableBody.querySelectorAll('tr');
                rows.forEach(row => {
                    const status = row.getAttribute('data-status');
                    if (filterValue === 'all' || status === filterValue) {
                        row.style.display = '';
                    } else {
                        row.style.display = 'none';
                    }
                });

                updateTaskCount();
            });
        });

        // Sorting Logic
        sortBtn.addEventListener('click', () => {
            const rows = Array.from(taskTableBody.querySelectorAll('tr'));

            rows.sort((a, b) => {
                const nameA = a.querySelector('.task-name').textContent.trim().toLowerCase();
                const nameB = b.querySelector('.task-name').textContent.trim().toLowerCase();

                if (currentSortOrder === 'asc') {
                    return nameA.localeCompare(nameB);
                } else {
                    return nameB.localeCompare(nameA);
                }
            });

            // Toggle Sort Order for next click
            currentSortOrder = currentSortOrder === 'asc' ? 'desc' : 'asc';

            // Re-append sorted rows
            rows.forEach(row => taskTableBody.appendChild(row));

            // Visual feedback (optional: update sort icon)
            const icon = sortBtn.querySelector('.material-symbols-outlined');
            icon.style.transform = currentSortOrder === 'asc' ? 'scaleY(1)' : 'scaleY(-1)';
        });
    </script>
