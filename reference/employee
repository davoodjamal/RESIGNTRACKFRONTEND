    <script>
// Form field interaction feedback
document.querySelectorAll('.input-field').forEach(input => {
    input.addEventListener('focus', () => {
        const section = input.closest('section');
        if (section) section.style.borderColor = '#0f52ba';
    });
    input.addEventListener('blur', () => {
        const section = input.closest('section');
        if (section) section.style.borderColor = 'transparent';
    });
});

// Modal Logic
const modal = document.getElementById('passwordModal');
const openBtn = document.getElementById('openChangePassword');
const backdrop = document.getElementById('modalBackdrop');
const successOverlay = document.getElementById('successOverlay');
const newPassInput = document.getElementById('newPass');

function openModal() {
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    successOverlay.classList.add('hidden');
}

function closeModal() {
    modal.classList.add('hidden');
    document.body.style.overflow = 'auto';
    // Reset fields
    document.querySelectorAll('#passwordModal input').forEach(i => i.value = '');
    document.getElementById('currError').classList.add('hidden');
    document.getElementById('matchError').classList.add('hidden');
}

openBtn.addEventListener('click', openModal);
backdrop.addEventListener('click', closeModal);

function togglePass(id) {
    const input = document.getElementById(id);
    const btn = input.nextElementSibling.querySelector('span');
    if (input.type === 'password') {
        input.type = 'text';
        btn.textContent = 'visibility_off';
    } else {
        input.type = 'password';
        btn.textContent = 'visibility';
    }
}

// Strength & Requirements Logic
newPassInput.addEventListener('input', (e) => {
    const val = e.target.value;
    const checks = {
        len: val.length >= 8,
        upper: /[A-Z]/.test(val),
        lower: /[a-z]/.test(val),
        num: /[0-9]/.test(val),
        spec: /[^A-Za-z0-9]/.test(val)
    };

    // Update icons
    for (let k in checks) {
        const el = document.getElementById('req-' + k);
        const icon = el.querySelector('span');
        if (checks[k]) {
            icon.textContent = 'check_circle';
            icon.classList.replace('text-outline', 'text-success');
            el.classList.replace('text-on-surface-variant', 'text-on-surface');
            icon.style.fontVariationSettings = "'FILL' 1";
        } else {
            icon.textContent = 'circle';
            icon.classList.replace('text-success', 'text-outline');
            el.classList.replace('text-on-surface', 'text-on-surface-variant');
            icon.style.fontVariationSettings = "'FILL' 0";
        }
    }

    // Strength bar
    const count = Object.values(checks).filter(Boolean).length;
    const text = document.getElementById('strengthText');
    const bars = [document.getElementById('strengthBar1'), document.getElementById('strengthBar2'), document.getElementById('strengthBar3')];

    bars.forEach(b => b.className = 'h-full w-1/3 transition-all bg-surface-container');

    if (count <= 2) {
        text.textContent = 'Weak';
        text.className = 'text-[11px] font-bold uppercase text-error';
        bars[0].classList.replace('bg-surface-container', 'bg-error');
    } else if (count <= 4) {
        text.textContent = 'Medium';
        text.className = 'text-[11px] font-bold uppercase text-amber-500';
        bars[0].classList.replace('bg-surface-container', 'bg-amber-500');
        bars[1].classList.replace('bg-surface-container', 'bg-amber-500');
    } else {
        text.textContent = 'Strong';
        text.className = 'text-[11px] font-bold uppercase text-success';
        bars.forEach(b => b.classList.replace('bg-surface-container', 'bg-success'));
    }
});

function handleUpdate() {
    const curr = document.getElementById('currPass').value;
    const pass = document.getElementById('newPass').value;
    const conf = document.getElementById('confirmPass').value;

    // Simulating error logic
    document.getElementById('currError').classList.add('hidden');
    document.getElementById('matchError').classList.add('hidden');

    if (curr === "") {
        document.getElementById('currError').classList.remove('hidden');
        return;
    }

    if (pass !== conf) {
        document.getElementById('matchError').classList.remove('hidden');
        return;
    }

    // Success simulation
    successOverlay.classList.remove('hidden');
}
</script>
