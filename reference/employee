        <script>
        (function () {
            const logoutBtn = document.querySelector('aside a[href="#"]');
            const container = document.getElementById('logout-modal-container');
            const content = document.getElementById('logout-modal-content');
            const overlay = document.getElementById('logout-modal-overlay');
            const closeBtn = document.getElementById('close-logout-modal');
            const cancelBtn = document.getElementById('cancel-logout');

            function openModal(e) {
                if (e) e.preventDefault();
                container.classList.remove('hidden');
                setTimeout(() => {
                    content.classList.remove('scale-95', 'opacity-0');
                    content.classList.add('scale-100', 'opacity-100');
                }, 10);
            }

            function closeModal() {
                content.classList.remove('scale-100', 'opacity-100');
                content.classList.add('scale-95', 'opacity-0');
                setTimeout(() => {
                    container.classList.add('hidden');
                }, 200);
            }

            if (logoutBtn) logoutBtn.addEventListener('click', openModal);
            if (overlay) overlay.addEventListener('click', closeModal);
            if (closeBtn) closeBtn.addEventListener('click', closeModal);
            if (cancelBtn) cancelBtn.addEventListener('click', closeModal);
        })();
</script>





