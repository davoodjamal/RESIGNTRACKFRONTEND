                <!-- Usage Chart Placeholder (Simplified line representation) -->
                <div
                    class="h-32 w-full bg-surface-container-low rounded-lg border border-outline-variant/20 flex items-center justify-center relative overflow-hidden">
                    <p class="text-on-surface-variant font-label-md absolute top-4 left-4">Hourly Activity (24h)</p>
                    <!-- Minimalist inline SVG for visual interest, representing a line chart -->
                    <svg class="w-full h-full opacity-40 pt-8" preserveaspectratio="none" viewbox="0 0 1000 100">
                        <path
                            d="M0,80 C100,80 150,20 250,50 C350,80 400,10 500,40 C600,70 650,30 750,60 C850,90 900,20 1000,50 L1000,100 L0,100 Z"
                            fill="url(#blue-gradient)"></path>
                        <path
                            d="M0,80 C100,80 150,20 250,50 C350,80 400,10 500,40 C600,70 650,30 750,60 C850,90 900,20 1000,50"
                            fill="none" stroke="#002764" stroke-width="2"></path>
                        <defs>
                            <lineargradient id="blue-gradient" x1="0%" x2="0%" y1="0%" y2="100%">
                                <stop offset="0%" stop-color="#002764" stop-opacity="0.2"></stop>
                                <stop offset="100%" stop-color="#002764" stop-opacity="0"></stop>
                            </lineargradient>
                        </defs>
                    </svg>
                </div>
            </div>
        </main>
    </div>
    <!-- Chart.js Initialization -->
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Colors matching Tailwind Config
            const primaryColor = '#002764';
            const secondaryColor = '#b0c6ff';
            const tertiaryColor = '#505f76';
            const gridColor = '#e2e2e9';
            const textColor = '#434652';

            // Chart Defaults
            Chart.defaults.font.family = 'Inter';
            Chart.defaults.color = textColor;
            Chart.defaults.scale.grid.color = gridColor;

            // Bar Chart: Monthly Attrition Trends
            const ctxBar = document.getElementById('attritionChart').getContext('2d');
            new Chart(ctxBar, {
                type: 'bar',
                data: {
                    labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
                    datasets: [
                        {
                            label: 'Voluntary',
                            data: [65, 59, 80, 81, 56, 55],
                            backgroundColor: primaryColor,
                            borderRadius: 4
                        },
                        {
                            label: 'Involuntary',
                            data: [28, 48, 40, 19, 86, 27],
                            backgroundColor: secondaryColor,
                            borderRadius: 4
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                usePointStyle: true,
                                padding: 20
                            }
                        }
                    },
                    scales: {
                        x: {
                            stacked: true,
                            grid: { display: false }
                        },
                        y: {
                            stacked: true,
                            beginAtZero: true,
                            border: { display: false }
                        }
                    }
                }
            });

            // Pie Chart: Top Exit Reasons
            const ctxPie = document.getElementById('exitReasonsChart').getContext('2d');
            new Chart(ctxPie, {
                type: 'doughnut',
                data: {
                    labels: ['Career Growth', 'Compensation', 'Work-Life Balance', 'Management', 'Other'],
                    datasets: [{
                        data: [35, 25, 20, 10, 10],
                        backgroundColor: [
                            primaryColor,
                            '#0f52ba', // primary-container
                            secondaryColor,
                            tertiaryColor,
                            '#e2e2e9'  // surface-variant
                        ],
                        borderWidth: 0,
                        hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '65%',
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                usePointStyle: true,
                                padding: 15,
                                font: {
                                    size: 11
                                }
                            }
                        }
                    }
                }
            });
        });
    </script>
</body>

</html>

