                            src="https://lh3.googleusercontent.com/aida-public/AB6AXuBWX8NF1nemxhiUju8-JvCtnepV782-TIltW8muyuW4UVJ3l6SFJFkw4IEOs0oJ-JLVL6_hGwJSWfNOijl41NM6DBRpAgjRNCv2T3UuWyEMs0wLHhkvHy9txkVvNMpaAj-UHT7t3s2dJx6EO3Kgbc-QwbwXG8b2XdukjUrztW6EvklAtBtBEeU0FKPMudXdL3aU_lC1EYfL8MjiCu_vV6oshCobrfggeo5reMJBhJYrqituqYt0Y4IFe5YZE-Ku9rOO5elVje_braI" />
                    </div>
                </div>
            </div>
        </header>
        <!-- Page Canvas -->
        <main class="flex-1 p-margin-desktop overflow-y-auto">
            <!-- Page Header & Actions -->
            <div class="flex items-center justify-between mb-8">
                <div>
                    <h2 class="font-display-lg text-display-lg text-on-surface">Reports &amp; Analytics</h2>
                    <p class="font-body-lg text-body-lg text-on-surface-variant mt-1">Monitor organization trends and
                        system utilization.</p>
                </div>
                <!-- Toggle Switch -->
                <div
                    class="flex items-center gap-3 bg-surface-container-lowest px-4 py-3 rounded-lg shadow-sm border border-outline-variant/30">
                    <div class="flex flex-col">
                        <span class="font-label-md text-label-md font-bold text-on-surface">Scheduled Summary</span>
                        <span class="text-xs text-on-surface-variant">Monthly reports via email</span>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer ml-2">
                        <input checked="" class="sr-only peer" type="checkbox" value="" />
                        <div
                            class="w-11 h-6 bg-surface-variant peer-focus:outline-none rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-primary">
                        </div>
                    </label>
                </div>
            </div>
            <!-- Bento Grid Layout for Charts -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-gutter mb-8">
                <!-- Monthly Attrition Trends (Large Bar Chart) -->
                <div
                    class="lg:col-span-2 bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/20 p-lg flex flex-col">
                    <div class="flex items-center justify-between mb-6">
                        <div>
                            <h3 class="font-headline-md text-headline-md text-on-surface">Monthly Attrition Trends</h3>
                            <p class="font-body-md text-body-md text-on-surface-variant">Voluntary vs Involuntary
                                departures over 6 months</p>
                        </div>
                        <button
                            class="p-2 hover:bg-surface-container rounded-full text-on-surface-variant transition-colors">
                            <span class="material-symbols-outlined">more_vert</span>
                        </button>
                    </div>
                    <div class="flex-1 relative h-64 min-h-[300px] w-full">
                        <canvas id="attritionChart"></canvas>
                    </div>
                </div>
                <!-- Top Exit Reasons (Pie Chart) -->
                <div
                    class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/20 p-lg flex flex-col">
                    <div class="flex items-center justify-between mb-6">
                        <div>
                            <h3 class="font-headline-sm text-headline-sm text-on-surface">Top Exit Reasons</h3>
                            <p class="font-label-md text-label-md text-on-surface-variant mt-1">YTD Aggregated Data</p>
                        </div>
                    </div>
                    <div class="flex-1 relative h-full min-h-[250px] w-full flex items-center justify-center">
                        <canvas id="exitReasonsChart"></canvas>
                    </div>
                </div>
            </div>
            <!-- System Usage Report Section -->
            <div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/20 p-lg">
                <div class="flex items-center justify-between mb-6">
                    <div>
                        <h3 class="font-headline-md text-headline-md text-on-surface">System Usage Report</h3>
                        <p class="font-body-md text-body-md text-on-surface-variant">Daily login volume and workflow
                            approval metrics</p>
                    </div>
                    <div class="flex gap-2">
                        <button
                            class="px-4 py-2 text-sm font-medium border border-outline-variant rounded-lg text-on-surface hover:bg-surface-container transition-colors">Export
                            CSV</button>
                        <button
                            class="px-4 py-2 text-sm font-medium bg-primary text-on-primary rounded-lg hover:bg-primary/90 transition-colors">View
                            Details</button>
                    </div>
                </div>
                <!-- Metrics Grid -->
                <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
                    <div class="p-4 rounded-lg bg-surface-container-low border border-outline-variant/20">
                        <p class="font-label-md text-label-md text-on-surface-variant uppercase mb-1">Total Logins
                            (Today)</p>
                        <p class="font-display-lg text-display-lg text-primary">1,248</p>
                        <div class="flex items-center gap-1 text-success mt-2">
                            <span class="material-symbols-outlined text-sm">trending_up</span>
                            <span class="font-label-md text-label-md">+12% vs yesterday</span>
                        </div>
                    </div>
                    <div class="p-4 rounded-lg bg-surface-container-low border border-outline-variant/20">
                        <p class="font-label-md text-label-md text-on-surface-variant uppercase mb-1">Workflows
                            Initiated</p>
                        <p class="font-display-lg text-display-lg text-on-surface">342</p>
                        <div class="flex items-center gap-1 text-success mt-2">
                            <span class="material-symbols-outlined text-sm">trending_up</span>
                            <span class="font-label-md text-label-md">+5% vs yesterday</span>
                        </div>
                    </div>
                    <div class="p-4 rounded-lg bg-surface-container-low border border-outline-variant/20">
                        <p class="font-label-md text-label-md text-on-surface-variant uppercase mb-1">Pending Approvals
