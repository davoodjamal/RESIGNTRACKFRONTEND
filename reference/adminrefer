                        <p class="font-display-lg text-display-lg text-error">24</p>
                        <div class="flex items-center gap-1 text-error mt-2">
                            <span class="material-symbols-outlined text-sm">warning</span>
                            <span class="font-label-md text-label-md">Investigate</span>
                        </div>
                    </div>
