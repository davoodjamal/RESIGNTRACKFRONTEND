                        <p class="font-display-lg text-display-lg text-secondary">89</p>
                        <div class="flex items-center gap-1 text-on-surface-variant mt-2">
                            <span class="material-symbols-outlined text-sm">schedule</span>
                            <span class="font-label-md text-label-md">Avg time: 4hrs</span>
                        </div>
                    </div>
                    <div class="p-4 rounded-lg bg-error-container/30 border border-error/20">
