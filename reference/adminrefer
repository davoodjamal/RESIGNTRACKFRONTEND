            class="w-full top-0 sticky z-40 bg-primary dark:bg-primary-container text-on-primary dark:text-on-primary-container flex items-center justify-between px-lg py-xs h-16 shadow-md">
            <!-- Branding / Title -->
            <div class="flex-1 font-headline-sm text-headline-sm text-on-primary font-bold truncate pr-4">
                System Announcements: Maintenance scheduled for Sunday at 02:00 AM UTC
            </div>
            <!-- Actions -->
            <div class="flex items-center gap-4">
                <!-- Search Icon (on left of actions as per spec 'on_left' implied intent for search) -->
                <button
                    class="p-2 rounded-full hover:bg-primary-fixed-variant/20 transition-colors text-on-primary-container/80 hover:text-on-primary">
                    <span class="material-symbols-outlined">search</span>
                </button>
                <!-- Trailing Icon Actions -->
                <button
                    class="p-2 rounded-full hover:bg-primary-fixed-variant/20 transition-colors text-on-primary-container/80 hover:text-on-primary relative">
                    <span class="material-symbols-outlined">notifications</span>
                    <span class="absolute top-1 right-1 w-2 h-2 bg-error rounded-full"></span>
                </button>
                <button
                    class="p-2 rounded-full hover:bg-primary-fixed-variant/20 transition-colors text-on-primary-container/80 hover:text-on-primary">
                    <span class="material-symbols-outlined">help</span>
                </button>
                <!-- Secondary Action & Profile -->
                <div class="flex items-center gap-3 pl-4 border-l border-on-primary-container/30">
                    <button
                        class="font-label-md text-label-md text-on-primary-container/80 hover:text-on-primary hover:bg-primary-fixed-variant/20 px-3 py-1.5 rounded-full transition-colors">
                        Settings
