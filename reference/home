</main>
<script>
        function togglePassword() {
            const input = document.getElementById('password');
            const icon = document.getElementById('passwordIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.innerText = 'visibility_off';
            } else {
                input.type = 'password';
                icon.innerText = 'visibility';
            }
        }

        async function handleLogin(event) {
            event.preventDefault();
            const btn = document.getElementById('submitBtn');
            const originalText = btn.innerHTML;
            
            // Interaction Feedback
            btn.disabled = true;
            btn.innerHTML = `<span class="animate-spin material-symbols-outlined">progress_activity</span> Authenticating...`;
            
            // Simulate API delay
            setTimeout(() => {
                btn.classList.add('bg-secondary');
                btn.innerHTML = `<span class="material-symbols-outlined">check_circle</span> Success`;
                
                // Final "Redirect" animation
                setTimeout(() => {
                    document.body.style.opacity = '0';
                    document.body.style.transition = 'opacity 0.5s ease-in-out';
                    // In a real app, window.location.href = '/dashboard' would happen here
                }, 800);
            }, 1500);
        }
    </script>


