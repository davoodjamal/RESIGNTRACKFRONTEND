<main class="min-h-screen flex items-center justify-center relative overflow-hidden bg-pattern px-margin-mobile md:px-margin-desktop">
<!-- Abstract Background Element -->
<div class="absolute inset-0 z-0 opacity-20 pointer-events-none">
<img class="w-full h-full object-cover" data-alt="A wide-angle shot of a high-tech, minimalist corporate office atrium with clean lines, glass partitions, and a palette of slate greys and whites. The lighting is diffused and professional, creating a sense of organizational stability and modern efficiency. Subtle reflections on polished surfaces add depth to the serene, high-stakes business environment." src="https://lh3.googleusercontent.com/aida-public/AB6AXuDktBqKRimN0yYbXvlik-9Ygrw4skd0xsk6JWMe7TelWqMD4F8guVQADtPIGN24woMFi8ij6JF_kxjzjZNnjfZwSRn1AC45M6RBIbsNql3v6PZCgL5JoH7v-Ppms4JpMbOezywwyIgvxq-hkuWuw65yWy2IEijuN7KXzTFepkPjnDgr02sELASBPxDkH64Pq4iri5PPtFUBmqweZyBPE7PZ_8HeRruRpjc8aZ2-p_-Trpf6bfT78atAIGhpiMR9vq6szAEzg-avgi3q">
</div>
<!-- Login Container -->
<div class="relative z-10 w-full max-w-[448px] animate-in fade-in slide-in-from-bottom-4 duration-700">
<!-- Logo Area -->
<div class="flex flex-col items-center mb-stack-lg">
<div class="flex items-center gap-unit mb-unit">
<span class="material-symbols-outlined text-secondary text-display-lg" style="font-variation-settings: 'FILL' 1;">account_tree</span>
<h1 class="font-headline-sm text-headline-sm font-black text-primary tracking-tight">RESIGN TRACK</h1>
</div>
<p class="font-body-md text-body-md text-on-surface-variant">Employee Exit &amp; Analysis Portal</p>
</div>
<!-- Login Card -->
<div class="bg-surface-container-lowest login-card rounded-xl p-stack-lg md:p-10">
<div class="mb-stack-lg">
<h2 class="font-headline-sm text-headline-sm text-on-surface mb-unit">Welcome</h2>
<p class="font-body-sm text-body-sm text-on-surface-variant">Enter your credentials to access the resignation management system.</p>
</div>
<form class="space-y-stack-md" id="loginForm" onsubmit="handleLogin(event)">
<!-- Email Field -->
<div class="space-y-unit mb-stack-md"><label class="font-body-sm text-body-sm font-bold text-on-surface">Select Role</label><div class="flex p-1 bg-surface border border-outline-variant rounded-lg gap-1"><label class="flex-1"><input type="radio" name="role" value="employee" class="sr-only peer" checked=""><div class="flex items-center justify-center py-2 rounded font-label-md text-label-md text-on-surface-variant cursor-pointer transition-all peer-checked:bg-primary peer-checked:text-on-primary hover:bg-secondary/5">Employee</div></label><label class="flex-1"><input type="radio" name="role" value="hr" class="sr-only peer"><div class="flex items-center justify-center py-2 rounded font-label-md text-label-md text-on-surface-variant cursor-pointer transition-all peer-checked:bg-primary peer-checked:text-on-primary hover:bg-secondary/5">HR Manager</div></label><label class="flex-1"><input type="radio" name="role" value="admin" class="sr-only peer"><div class="flex items-center justify-center py-2 rounded font-label-md text-label-md text-on-surface-variant cursor-pointer transition-all peer-checked:bg-primary peer-checked:text-on-primary hover:bg-secondary/5">Admin</div></label></div></div><div class="space-y-unit">
<label class="font-body-sm text-body-sm font-bold text-on-surface" for="email">Email Address</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-[20px]">mail</span>
<input class="w-full pl-10 pr-4 py-3 bg-surface border border-outline-variant rounded-lg font-body-md text-body-md focus:outline-none focus:ring-2 focus:ring-secondary/20 focus:border-secondary transition-all" id="email" placeholder="name@softwarecorp.com" required="" type="email">
</div>
</div>
<!-- Password Field -->
<div class="space-y-unit">
<div class="flex justify-between items-center">
<label class="font-body-sm text-body-sm font-bold text-on-surface" for="password">Password</label>
<a class="font-label-md text-label-md text-secondary hover:underline" href="#">Forgot password?</a>
</div>
<div class="relative">
<span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-[20px]">lock</span>
<input class="w-full pl-10 pr-12 py-3 bg-surface border border-outline-variant rounded-lg font-body-md text-body-md focus:outline-none focus:ring-2 focus:ring-secondary/20 focus:border-secondary transition-all" id="password" placeholder="••••••••" required="" type="password">
<button class="absolute right-3 top-1/2 -translate-y-1/2 text-outline hover:text-on-surface-variant transition-colors" onclick="togglePassword()" type="button">
<span class="material-symbols-outlined text-[20px]" id="passwordIcon">visibility</span>
</button>
</div>
</div>
